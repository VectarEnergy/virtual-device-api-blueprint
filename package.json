{
  "name": "virtual-device-api-blueprint",
  "version": "1.0.0",
  "description": "Production-ready Node.js/Express API blueprint",
  "main": "dist/app.js",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn src/app.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "catchup": "npm run build && node scripts/run-catchup.js",
    "catchup:fresh": "npm run build && node scripts/reset-and-catchup.js",
    "reconcile": "npm run build && node scripts/reconcile-solar-yield.js",
    "rebuild:daily": "npm run build && node scripts/rebuild-daily-from-vrm.js",
    "ci": "npm run build && npm run test",
    "docker:build": "docker build -t virtual-device-api-blueprint:latest .",
    "compose:up": "docker-compose up --build"
  },
  "dependencies": {
    "@types/axios": "^0.9.36",
    "@types/express": "^5.0.6",
    "axios": "^1.13.2",
    "dayjs": "^1.11.19",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "joi": "^17.9.2",
    "pg": "^8.10.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.32.1",
    "sqlite3": "^5.1.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.3",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
